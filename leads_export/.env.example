# leads_export/.env — copy to .env and fill in. NEVER commit .env (it is gitignored).

# Identity Supabase project (coshondiqdhorwvibrwu) — the one the mobile app syncs to.
IDENTITY_SUPABASE_URL=https://coshondiqdhorwvibrwu.supabase.co
# Service role key: Supabase dashboard -> project coshondiqdhorwvibrwu -> Settings -> API.
# Needed to read every user's leads (bypasses RLS) and download private media.
IDENTITY_SUPABASE_SERVICE_ROLE_KEY=

# The shared Google Drive folder that holds the leads-dp sheet + the two subfolders.
LEADS_PARENT_FOLDER_ID=1sjzeBLO4lOgZ1O0fSFjXdEDoj8mrMw-z

# --- Optional overrides (defaults shown) ---
# LEADS_SHEET_NAME=leads-dp
# LEADS_SHEET_TAB=            # blank = first tab of the spreadsheet
# LEADS_CARDS_FOLDER=visiting cards
# LEADS_VOICE_FOLDER=voice notes
# GOOGLE_CREDENTIALS_FILE=credentials.json   # copied from FETCH DAILY DATA
# GOOGLE_TOKEN_FILE=token_leads.json         # created on first run
# RUN_CONSOLE=1              # set on a headless machine (no browser) for OAuth consent
