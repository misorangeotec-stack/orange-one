# =============================================================================
# Environment variables for the WAT framework
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored and is
# the ONLY place secrets should ever live. Tools read these via tools/config.py.
# =============================================================================

# --- LLM / AI providers ------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Google APIs (Sheets, Slides, Drive) -------------------------------------
# OAuth client downloaded from Google Cloud Console -> credentials.json
# token.json is generated on first auth. Both are gitignored.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# --- Web scraping ------------------------------------------------------------
FIRECRAWL_API_KEY=

# --- Add other service keys below as tools require them ----------------------
