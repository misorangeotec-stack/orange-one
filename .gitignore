# Secrets & credentials — NEVER commit these
.env
credentials.json
token.json
*.pem
*.key

# Temporary / regenerable files
.tmp/
*.log

# Database backups — contain real user data (PII). NEVER commit.
backups/
*.dump
*.sql.gz

# Node / frontend (React + Vite)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/*.local
.vite/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Supabase CLI scratch state
supabase/.temp/
