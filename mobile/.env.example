# Supabase connection — copy this file to `.env` and fill in the values.
#
# The mobile app talks to the SAME Supabase project as the Orange One web app
# (the Task Management / identity project, ref `coshondiqdhorwvibrwu`), so staff
# sign in with their existing Orange One accounts. The values below are the same
# ones the web app uses for VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.
#
# These use the EXPO_PUBLIC_ prefix so Expo inlines them into the app bundle at
# build time. The anon key is a *publishable* key (safe in a client) — data is
# protected by Row-Level Security, not by hiding this key. NEVER put the
# service_role key here.
#
# After editing .env you must restart the dev server (stop and re-run
# `npx expo start`) for the new values to take effect.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
